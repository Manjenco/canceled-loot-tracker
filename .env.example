# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The guild-wide master sheet holds all shared/static data and the team registry.
# The Teams tab in this sheet is the only place to register raid teams — no per-team
# env vars needed. Sheet ID is the long string in the URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
MASTER_SHEET_ID=your_master_sheet_id_here

# Local dev: path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account.json
# Railway/production: paste the entire JSON as a single-line string instead:
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# ── Web app ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string-in-production
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
# CLIENT_URL=http://localhost:3000   # dev default; set to your domain in production
# WEB_PORT=3001                      # default 3001
